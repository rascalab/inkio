{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@inkio/core": [
        "../../packages/core/src/index.ts"
      ],
      "@inkio/core/*": [
        "../../packages/core/src/*"
      ],
      "@inkio/essential": [
        "../../packages/essential/src/index.ts"
      ],
      "@inkio/essential/*": [
        "../../packages/essential/src/*"
      ],
      "@inkio/editor": [
        "../../packages/editor/src/index.ts"
      ],
      "@inkio/editor/icons": [
        "../../packages/editor/src/icons/index.ts"
      ],
      "@inkio/advanced": [
        "../../packages/advanced/src/index.ts"
      ],
      "@inkio/advanced/*": [
        "../../packages/advanced/src/*"
      ],
      "@inkio/image-editor": [
        "../../packages/image-editor/src/index.ts"
      ],
      "@inkio/image-editor/*": [
        "../../packages/image-editor/src/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
