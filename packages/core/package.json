{
  "name": "@inkio/core",
  "version": "0.0.5",
  "description": "Inkio editor foundation primitives",
  "license": "MIT",
  "keywords": [
    "inkio",
    "editor",
    "rich-text-editor",
    "tiptap",
    "react",
    "viewer",
    "foundation"
  ],
  "homepage": "https://rascalab.github.io/inkio/",
  "bugs": {
    "url": "https://github.com/rascalab/inkio/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rascalab/inkio.git",
    "directory": "packages/core"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/icons.js",
      "require": "./dist/icons.cjs"
    },
    "./markdown": {
      "types": "./dist/markdown.d.ts",
      "import": "./dist/markdown.js",
      "require": "./dist/markdown.cjs"
    },
    "./style.css": "./dist/style.css",
    "./minimal.css": "./dist/minimal.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "bundle:smoke": "INKIO_VITE_SKIP_DTS=1 node ../../scripts/run-vite-package-build.mjs",
    "bundle": "node ../../scripts/run-vite-package-build.mjs",
    "build": "pnpm typecheck && pnpm bundle",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@radix-ui/react-popover": "^1.1.15",
    "@tiptap/core": "^3.20.4",
    "@tiptap/extension-blockquote": "^3.20.4",
    "@tiptap/extension-bold": "^3.20.4",
    "@tiptap/extension-bullet-list": "^3.20.4",
    "@tiptap/extension-code": "^3.20.4",
    "@tiptap/extension-code-block": "^3.20.4",
    "@tiptap/extension-code-block-lowlight": "^3.20.4",
    "@tiptap/extension-color": "^3.20.4",
    "@tiptap/extension-details": "^3.20.4",
    "@tiptap/extension-document": "^3.20.4",
    "@tiptap/extension-dropcursor": "^3.20.4",
    "@tiptap/extension-gapcursor": "^3.20.4",
    "@tiptap/extension-hard-break": "^3.20.4",
    "@tiptap/extension-heading": "^3.20.4",
    "@tiptap/extension-highlight": "^3.20.4",
    "@tiptap/extension-history": "^3.20.4",
    "@tiptap/extension-horizontal-rule": "^3.20.4",
    "@tiptap/extension-italic": "^3.20.4",
    "@tiptap/extension-link": "^3.20.4",
    "@tiptap/extension-list": "^3.20.4",
    "@tiptap/extension-list-item": "^3.20.4",
    "@tiptap/extension-ordered-list": "^3.20.4",
    "@tiptap/extension-paragraph": "^3.20.4",
    "@tiptap/extension-placeholder": "^3.20.4",
    "@tiptap/extension-strike": "^3.20.4",
    "@tiptap/extension-subscript": "^3.20.4",
    "@tiptap/extension-superscript": "^3.20.4",
    "@tiptap/extension-table": "^3.20.4",
    "@tiptap/extension-table-cell": "^3.20.4",
    "@tiptap/extension-table-header": "^3.20.4",
    "@tiptap/extension-table-row": "^3.20.4",
    "@tiptap/extension-task-item": "^3.20.4",
    "@tiptap/extension-task-list": "^3.20.4",
    "@tiptap/extension-text": "^3.20.4",
    "@tiptap/extension-text-align": "^3.20.4",
    "@tiptap/extension-text-style": "^3.20.4",
    "@tiptap/extension-underline": "^3.20.4",
    "@tiptap/extensions": "^3.20.4",
    "@tiptap/html": "^3.20.4",
    "@tiptap/pm": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@tiptap/suggestion": "^3.20.4",
    "happy-dom": "^20.8.4",
    "lowlight": "^3.3.0",
    "lucide": "^0.577.0",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "sanitize-html": "^2.17.2",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^28.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.0"
  }
}
