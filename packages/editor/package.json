{
  "name": "@inkio/editor",
  "version": "0.0.5",
  "description": "Opinionated notion-like entry point for Inkio",
  "license": "MIT",
  "keywords": [
    "inkio",
    "editor",
    "rich-text-editor",
    "tiptap",
    "react",
    "viewer",
    "wysiwyg",
    "notion-like"
  ],
  "homepage": "https://rascalab.github.io/inkio/",
  "bugs": {
    "url": "https://github.com/rascalab/inkio/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rascalab/inkio.git",
    "directory": "packages/editor"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/icons.js",
      "require": "./dist/icons.cjs"
    },
    "./markdown": {
      "types": "./dist/markdown.d.ts",
      "import": "./dist/markdown.js",
      "require": "./dist/markdown.cjs"
    },
    "./style.css": "./dist/style.css",
    "./minimal.css": "./dist/style-minimal.css",
    "./style-minimal.css": "./dist/style-minimal.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "build": "pnpm typecheck && vite build",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@inkio/advanced": "workspace:^",
    "@inkio/core": "workspace:^"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^28.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.0"
  }
}
