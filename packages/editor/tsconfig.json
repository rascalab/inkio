{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@inkio/core": ["../core/src/index.ts"],
      "@inkio/core/*": ["../core/src/*"],
      "@inkio/essential": ["../essential/src/index.ts"],
      "@inkio/essential/*": ["../essential/src/*"],
      "@inkio/advanced": ["../advanced/src/index.ts"],
      "@inkio/advanced/*": ["../advanced/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
