{
  "name": "@inkio/essential",
  "version": "0.0.5",
  "description": "Essential document authoring extensions for Inkio",
  "license": "MIT",
  "homepage": "https://rascalab.github.io/inkio/",
  "bugs": {
    "url": "https://github.com/rascalab/inkio/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rascalab/inkio.git",
    "directory": "packages/essential"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./callout": {
      "types": "./dist/callout.d.ts",
      "import": "./dist/callout.js",
      "require": "./dist/callout.cjs"
    },
    "./keyboard-shortcuts": {
      "types": "./dist/keyboard-shortcuts.d.ts",
      "import": "./dist/keyboard-shortcuts.js",
      "require": "./dist/keyboard-shortcuts.cjs"
    }
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "bundle:smoke": "INKIO_VITE_SKIP_DTS=1 node ../../scripts/run-vite-package-build.mjs",
    "bundle": "node ../../scripts/run-vite-package-build.mjs",
    "build": "pnpm typecheck && pnpm bundle",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@inkio/core": "workspace:^",
    "@tiptap/core": "^3.20.4",
    "@tiptap/extension-details": "^3.20.4",
    "@tiptap/extension-table": "^3.20.4",
    "@tiptap/extension-table-cell": "^3.20.4",
    "@tiptap/extension-table-header": "^3.20.4",
    "@tiptap/extension-table-row": "^3.20.4",
    "@tiptap/pm": "^3.20.4",
    "@tiptap/react": "^3.20.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@tiptap/extension-document": "^3.20.4",
    "@tiptap/extension-paragraph": "^3.20.4",
    "@tiptap/extension-text": "^3.20.4",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^28.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.0"
  }
}
