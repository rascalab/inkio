{
  "name": "@inkio/extension",
  "version": "0.0.3",
  "description": "Feature extensions for Inkio",
  "license": "MIT",
  "keywords": [
    "inkio",
    "editor",
    "rich-text-editor",
    "tiptap",
    "react",
    "extensions",
    "mention",
    "wikilink",
    "image"
  ],
  "homepage": "https://rascalab.github.io/inkio/",
  "bugs": {
    "url": "https://github.com/rascalab/inkio/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rascalab/inkio.git",
    "directory": "packages/extensions"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./mention": {
      "types": "./dist/mention.d.ts",
      "import": "./dist/mention.js",
      "require": "./dist/mention.cjs"
    },
    "./hashtag": {
      "types": "./dist/hashtag.d.ts",
      "import": "./dist/hashtag.js",
      "require": "./dist/hashtag.cjs"
    },
    "./slash-command": {
      "types": "./dist/slash-command.d.ts",
      "import": "./dist/slash-command.js",
      "require": "./dist/slash-command.cjs"
    },
    "./wikilink": {
      "types": "./dist/wikilink.d.ts",
      "import": "./dist/wikilink.js",
      "require": "./dist/wikilink.cjs"
    },
    "./callout": {
      "types": "./dist/callout.d.ts",
      "import": "./dist/callout.js",
      "require": "./dist/callout.cjs"
    },
    "./image": {
      "types": "./dist/image.d.ts",
      "import": "./dist/image.js",
      "require": "./dist/image.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@inkio/editor": "^0.0.1",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@tiptap/core": "^3.20.1",
    "@tiptap/extension-details": "^3.20.1",
    "@tiptap/extension-table": "^3.20.1",
    "@tiptap/extension-table-cell": "^3.20.1",
    "@tiptap/extension-table-header": "^3.20.1",
    "@tiptap/extension-table-row": "^3.20.1",
    "@tiptap/extension-text-style": "^3.20.1",
    "@tiptap/pm": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/suggestion": "^3.20.1",
    "katex": "^0.16.38",
    "konva": "^10.2.0",
    "lucide": "^0.577.0",
    "lucide-react": "^0.577.0",
    "react-konva": "^19.2.3"
  },
  "devDependencies": {
    "@inkio/editor": "workspace:^",
    "@testing-library/jest-dom": "^6.9.1",
    "@tiptap/extension-document": "^3.20.1",
    "@tiptap/extension-paragraph": "^3.20.1",
    "@tiptap/extension-text": "^3.20.1",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^28.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  }
}
